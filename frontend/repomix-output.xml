                :rows="3"
                :disabled="isAityping"
                @keydown="handelKeydown"
                class="message-input"
                clearable></el-input>
            <div class="input-footer">
              <span>按enter发送，按shift+enter换行</span>
              <span>{{userMessage.length}}/500</span>
          </div>
             </div>
        <el-button :disabled="userMessage.length === 0 ||userMessage.length > 500" class="send-btn" type="primary" @click="sendMessage">
           <el-icon><Promotion /></el-icon>
        </el-button>
         </div>
     </div>

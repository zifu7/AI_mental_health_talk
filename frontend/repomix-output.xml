                  <el-image v-if="msg.senderType===2" :src="iconUrl1" style="width: 18px; height: 18px;" alt="AI助手图标" />
                  <el-image v-else :src="iconUrl3" alt="用户头像" style="width: 18px; height: 18px;" />
             </div>
